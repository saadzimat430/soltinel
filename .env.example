# ---- LLM (pick one; OpenRouter wins if multiple are set) ----
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...                  # optional alternative
# OPENROUTER_API_KEY=sk-or-...           # routes via OpenRouter
# OPENROUTER_MODEL=anthropic/claude-opus-4
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Solana ----
# Base58-encoded private key for the trading wallet. NEVER commit.
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ---- Data sources ----
# https://docs.birdeye.so/  (free tier works for price + token_overview)
BIRDEYE_API_KEY=
# RugCheck is public; no key required by default. Override if you have one.
RUGCHECK_BASE_URL=https://api.rugcheck.xyz/v1

# ---- X / Twitter (optional) ----
# Bearer token for X API v2. If omitted, the sentiment agent falls back to
# a stub search (returns empty posts) and scores as neutral.
X_BEARER_TOKEN=

# ---- Bot policy ----
MAX_TRADE_USD=25           # max USDC to spend per trade
MAX_SLIPPAGE_BPS=100       # Jupiter swap slippage tolerance (100 = 1%)

# Risk thresholds — all are hard rules (fail = automatic reject before LLM)
RUG_SCORE_MAX=40           # reject if rug risk score > this (0-100). Lower = stricter.
SENTIMENT_MIN=0.45         # reject if bullish sentiment score < this (0-1). Higher = stricter.
MIN_LIQUIDITY_USD=5000     # reject if pool liquidity < this in USD
MIN_VOLUME_24H_USD=1000    # reject if 24h trading volume < this in USD
MIN_VOL_LIQ_RATIO=0.01     # reject if volume/liquidity ratio < this (0.01 = 1% daily turnover)
MAX_PRICE_CHANGE_24H=-25   # reject if 24h price change < this % (e.g. -25 rejects drops > 25%)

DRY_RUN=true               # if true, Executor logs the swap but does not sign
REQUIRE_CONFIRMATION=true  # if true, prompts "y/n" before every real trade
ALLOW_OVERRIDE=false       # if true, offers an override prompt after any rejection (off by default)
